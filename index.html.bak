<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Azucon Contabilidade - Soluções contábeis personalizadas em Nova Granada. Abertura de empresa, MEI, Imposto de Renda, Folha de Pagamento.">
    <meta name="keywords" content="contabilidade, contador, MEI, PJ, imposto de renda, nova granada">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    
    <title>Azucon Contabilidade | Soluções Contábeis em Nova Granada</title>
    
    <style>
        :root {
            --primary: #001f5c;
            --primary-light: #0066cc;
            --accent: #06b6d4;
            --white: #ffffff;
            --gray-50: #f9fafb;
            --gray-100: #f3f4f6;
            --gray-200: #e5e7eb;
            --gray-700: #374151;
            --gray-900: #111827;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: 'Inter', sans-serif;
            color: var(--gray-700);
            background: var(--white);
            line-height: 1.6;
        }

        .container {
            max-width: 1280px;
            margin: 0 auto;
            padding: 0 2rem;
        }

        /* ===== HEADER ===== */
        nav {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 1.2rem 0;
        }

        header {
            position: sticky;
            top: 0;
            z-index: 100;
            background: var(--white);
            border-bottom: 1px solid var(--gray-200);
            backdrop-filter: blur(10px);
            background-color: rgba(255, 255, 255, 0.95);
            padding: 0.8rem 0;
        }

        .logo {
            font-size: 1.5rem;
            font-weight: 800;
            color: var(--primary);
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .nav-menu {
            display: flex;
            gap: 2.5rem;
            list-style: none;
        }

        .nav-menu a {
            color: var(--gray-700);
            text-decoration: none;
            font-weight: 600;
            font-size: 0.95rem;
            transition: color 0.3s;
        }

        .nav-menu a:hover {
            color: var(--primary-light);
        }

        .nav-cta {
            display: flex;
            gap: 1.5rem;
            align-items: center;
        }

        .btn {
            padding: 0.7rem 1.5rem;
            border: none;
            border-radius: 0.4rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
            font-size: 0.95rem;
            font-family: 'Inter', sans-serif;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--accent), #00d4ff);
            color: var(--primary);
            box-shadow: 0 4px 15px rgba(6, 182, 212, 0.3);
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(0, 31, 92, 0.4);
            background: linear-gradient(135deg, #0066cc, #0066cc);
            color: var(--white);
        }

        @media (max-width: 768px) {
            .nav-menu {
                display: none;
            }

            .container {
                padding: 0 1.5rem;
            }
        }

        /* ===== HERO SECTION ===== */
        .hero {
            background: linear-gradient(135deg, var(--primary) 0%, #002e8f 100%);
            color: var(--white);
            padding: 5rem 0 4rem;
            position: relative;
            overflow: hidden;
        }

        .hero::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -20%;
            width: 600px;
            height: 600px;
            background: radial-gradient(circle, rgba(6, 182, 212, 0.2) 0%, transparent 70%);
            border-radius: 50%;
            pointer-events: none;
        }

        .hero-content {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 4rem;
            align-items: center;
            position: relative;
            z-index: 10;
        }

        .hero-text h1 {
            font-size: clamp(2rem, 8vw, 3.5rem);
            font-weight: 800;
            line-height: 1.2;
            margin-bottom: 1.5rem;
        }

        .hero-text > p {
            font-size: 1.05rem;
            opacity: 0.95;
            margin-bottom: 2rem;
            line-height: 1.7;
        }

        .hero-benefits {
            display: flex;
            flex-direction: column;
            gap: 1rem;
            margin-bottom: 2.5rem;
        }

        .benefit {
            display: flex;
            align-items: center;
            gap: 1rem;
            font-weight: 500;
            opacity: 0.9;
        }

        .benefit::before {
            content: '✓';
            flex-shrink: 0;
            width: 24px;
            height: 24px;
            background: var(--accent);
            color: var(--primary);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            font-size: 0.9rem;
        }

        .hero-ctas {
            display: flex;
            gap: 1.5rem;
            margin-bottom: 0;
        }

        .btn-secondary {
            background: transparent;
            border: 2px solid var(--white);
            color: var(--white);
        }

        .btn-secondary:hover {
            background: var(--white);
            color: var(--primary);
        }

        .hero-image {
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .hero-image-placeholder {
            width: 100%;
            max-width: 450px;
            aspect-ratio: 1;
            background: radial-gradient(circle at 30% 30%, rgba(6, 182, 212, 0.3), rgba(0, 102, 204, 0.1));
            border-radius: 1.5rem;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 2px dashed rgba(255, 255, 255, 0.3);
            font-size: 3rem;
            color: rgba(255, 255, 255, 0.7);
        }

        @media (max-width: 1024px) {
            .hero-content {
                grid-template-columns: 1fr;
            }

            .hero-image-placeholder {
                display: none;
            }

            .hero-ctas {
                flex-direction: column;
            }
        }

        /* ===== SECTION STYLES ===== */
        section {
            padding: 5rem 0;
        }

        section:nth-child(even) {
            background: var(--gray-50);
        }

        .section-header {
            text-align: center;
            margin-bottom: 4rem;
        }

        .section-tag {
            display: inline-block;
            font-size: 0.85rem;
            font-weight: 700;
            color: var(--accent);
            margin-bottom: 1rem;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .section-header h2 {
            font-size: clamp(1.8rem, 5vw, 2.8rem);
            font-weight: 800;
            color: var(--primary);
            margin-bottom: 1rem;
            line-height: 1.3;
        }

        .section-header p {
            max-width: 600px;
            margin: 0 auto;
            color: var(--gray-700);
            font-size: 1.05rem;
        }

        /* ===== CARDS GRID ===== */
        .grid {
            display: grid;
            gap: 2rem;
            margin-bottom: 2rem;
        }

        .grid.cols-3 {
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        }

        .grid.cols-4 {
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        }

        .card {
            background: var(--white);
            border: 1px solid var(--gray-200);
            border-radius: 1rem;
            padding: 2rem;
            transition: all 0.3s;
            text-align: center;
        }

        .card:hover {
            border-color: var(--primary);
            background: linear-gradient(135deg, rgba(0, 31, 92, 0.05) 0%, rgba(0, 102, 204, 0.05) 100%);
            box-shadow: 0 10px 30px rgba(0, 31, 92, 0.15);
            transform: translateY(-5px);
        }

        .card-icon {
            font-size: 2.5rem;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            justify-content: center;
            height: auto;
            width: auto;
            background: none;
            margin-left: auto;
            margin-right: auto;
        }

        .card-icon svg {
            width: 48px;
            height: 48px;
        }

        .card.featured {
            background: var(--white);
            color: var(--gray-700);
            border: 1px solid var(--gray-200);
            grid-column: auto;
            position: relative;
            overflow: hidden;
        }

        .card.featured h3 {
            color: var(--primary);
        }

        .card.featured p {
            color: var(--gray-700);
        }

        .card.featured .card-link {
            color: var(--accent);
            font-weight: 600;
        }

        .card.featured:hover {
            border-color: var(--primary);
            background: linear-gradient(135deg, rgba(0, 31, 92, 0.05) 0%, rgba(0, 102, 204, 0.05) 100%);
            box-shadow: 0 10px 30px rgba(0, 31, 92, 0.15);
            transform: translateY(-5px);
        }

        .card h3 {
            font-size: 1.3rem;
            font-weight: 700;
            color: var(--primary);
            margin-bottom: 1rem;
        }

        .card p {
            color: var(--gray-700);
            font-size: 0.95rem;
            margin-bottom: 1.5rem;
            min-height: 60px;
        }

        .card-link {
            display: inline-block;
            color: var(--accent);
            font-weight: 600;
            text-decoration: none;
            transition: color 0.3s;
        }

        .card-link:hover {
            color: var(--primary-light);
        }

        /* ===== ABOUT SECTION ===== */
        .about-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 4rem;
            align-items: center;
        }

        .about-content h2 {
            font-size: 2.5rem;
            font-weight: 800;
            color: var(--primary);
            margin-bottom: 1.5rem;
            line-height: 1.3;
        }

        .about-content p {
            color: var(--gray-700);
            font-size: 1.05rem;
            line-height: 1.8;
            margin-bottom: 1.5rem;
        }

        .about-list {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 1rem;
            margin: 2rem 0;
        }

        .about-list li {
            display: flex;
            align-items: center;
            gap: 1rem;
            padding: 1rem;
            background: var(--white);
            border-radius: 0.75rem;
            border-left: 3px solid var(--accent);
            color: var(--gray-700);
            font-weight: 500;
            transition: all 0.3s;
        }

        .about-list li:hover {
            transform: translateX(5px);
            box-shadow: 0 4px 12px rgba(6, 182, 212, 0.1);
        }

        .about-list li::before {
            content: '✓';
            flex-shrink: 0;
            width: 28px;
            height: 28px;
            background: var(--accent);
            color: var(--primary);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            font-size: 1rem;
        }

        .about-image {
            width: 100%;
            aspect-ratio: 1;
            background: linear-gradient(135deg, rgba(6, 182, 212, 0.1) 0%, rgba(0, 102, 204, 0.1) 100%);
            border-radius: 1.5rem;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 2px dashed var(--gray-300);
            font-size: 4rem;
        }

        @media (max-width: 1024px) {
            .about-grid {
                grid-template-columns: 1fr;
            }

            .about-image {
                order: -1;
            }
        }

        /* ===== CTA DESTAQUE ===== */
        .featured-cta {
            background: linear-gradient(135deg, var(--primary) 0%, #002e8f 100%);
            color: var(--white);
            padding: 5rem 0;
            position: relative;
            overflow: hidden;
        }

        .featured-cta-content {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 4rem;
            align-items: center;
            position: relative;
            z-index: 10;
        }

        .featured-cta h2 {
            font-size: 2.5rem;
            font-weight: 800;
            line-height: 1.3;
            margin-bottom: 1.5rem;
        }

        .featured-cta p {
            font-size: 1.05rem;
            opacity: 0.95;
            margin-bottom: 2rem;
            line-height: 1.7;
        }

        .featured-cta-image {
            display: flex;
            justify-content: center;
        }

        .featured-cta-placeholder {
            width: 100%;
            max-width: 400px;
            aspect-ratio: 3/4;
            background: radial-gradient(circle at 40% 40%, rgba(6, 182, 212, 0.3), rgba(0, 102, 204, 0.1));
            border-radius: 1.5rem;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 2px dashed rgba(255, 255, 255, 0.3);
            font-size: 3rem;
            color: rgba(255, 255, 255, 0.7);
        }

        @media (max-width: 1024px) {
            .featured-cta-content {
                grid-template-columns: 1fr;
            }

            .featured-cta-placeholder {
                display: none;
            }
        }

        /* ===== TESTIMONIALS ===== */
        .testimonials-header {
            margin-bottom: 3rem;
        }

        .testimonial-badge {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 1rem;
            margin-bottom: 3rem;
            flex-wrap: wrap;
        }

        .rating-box {
            background: var(--white);
            padding: 1rem 2rem;
            border-radius: 2rem;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .stars {
            color: #fbbf24;
            font-size: 1.1rem;
        }

        .testimonial-cards {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 2rem;
        }

        .testimonial-card {
            background: var(--white);
            padding: 2rem;
            border-radius: 1rem;
            border: 1px solid var(--gray-200);
            transition: all 0.3s;
            position: relative;
            overflow: hidden;
        }

        .testimonial-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(0, 102, 204, 0.1), transparent);
            transition: left 0.6s cubic-bezier(0.4, 0, 0.2, 1);
            pointer-events: none;
        }

        .testimonial-card:hover {
            border-color: var(--primary);
            box-shadow: 0 15px 40px rgba(0, 31, 92, 0.15);
            transform: translateY(-8px);
        }

        .testimonial-card:hover::before {
            left: 100%;
        }

        .testimonial-text {
            color: var(--gray-700);
            margin-bottom: 2rem;
            font-size: 0.95rem;
            line-height: 1.8;
            min-height: 90px;
        }

        .testimonial-author {
            display: flex;
            align-items: center;
            gap: 1rem;
            padding-top: 1.5rem;
            border-top: 1px solid var(--gray-200);
        }

        .author-avatar {
            width: 48px;
            height: 48px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--primary), var(--accent));
            color: var(--white);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 0.9rem;
        }

        .author-name {
            font-weight: 700;
            color: var(--gray-900);
            font-size: 0.95rem;
            margin-bottom: 0.25rem;
        }

        .author-role {
            font-size: 0.85rem;
            color: var(--gray-700);
            margin-bottom: 0.5rem;
        }

        /* ===== FAQ ===== */
        .faq-container {
            max-width: 800px;
            margin: 0 auto;
        }

        #faq {
            background: linear-gradient(180deg, rgba(0, 31, 92, 0.03) 0%, rgba(6, 182, 212, 0.03) 100%);
        }

        .faq-item {
            border-bottom: 1px solid var(--gray-200);
            padding: 2rem 0;
            transition: all 0.3s;
            background: var(--white);
            margin-bottom: 1rem;
            padding: 2rem;
            border-radius: 1rem;
            border: 1px solid var(--gray-200);
            border-bottom: none;
        }

        .faq-item:last-child {
            border-bottom: none;
        }

        .faq-item:hover {
            border-color: var(--primary);
            background: linear-gradient(135deg, rgba(0, 31, 92, 0.05) 0%, rgba(6, 182, 212, 0.05) 100%);
            box-shadow: 0 4px 12px rgba(0, 31, 92, 0.1);
        }

        .faq-question {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 2rem;
            cursor: pointer;
            user-select: none;
            color: var(--primary);
            font-weight: 700;
            font-size: 1.05rem;
            transition: color 0.3s;
        }

        .faq-question:hover {
            color: var(--primary-light);
        }

        .faq-icon {
            flex-shrink: 0;
            font-size: 1.5rem;
            transition: transform 0.3s;
            color: var(--accent);
            width: 24px;
            height: 24px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
        }

        .faq-item.active .faq-icon {
            transform: rotate(180deg);
        }

        .faq-answer {
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.3s, padding-top 0.3s;
            color: var(--gray-700);
            padding-top: 0;
        }

        .faq-item.active .faq-answer {
            max-height: 300px;
            padding-top: 1.5rem;
        }

        /* ===== CONTACT SECTION ===== */
        .contact {
            background: linear-gradient(135deg, var(--primary) 0%, #002e8f 100%);
            color: var(--white);
            padding: 5rem 0;
        }

        .contact h2 {
            font-size: 2.5rem;
            font-weight: 800;
            margin-bottom: 1.5rem;
            line-height: 1.3;
        }

        .contact > .container > p {
            max-width: 600px;
            margin: 0 auto 3rem;
            font-size: 1.05rem;
            opacity: 0.95;
            text-align: center;
        }

        .contact-methods {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 2rem;
        }

        .contact-method {
            background: rgba(255, 255, 255, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 1rem;
            padding: 2rem;
            backdrop-filter: blur(10px);
            transition: all 0.3s;
        }

        .contact-method:hover {
            background: rgba(255, 255, 255, 0.15);
            border-color: var(--accent);
        }

        .contact-method h4 {
            color: var(--white);
            font-size: 1.1rem;
            margin-bottom: 1rem;
        }

        .contact-method p {
            color: rgba(255, 255, 255, 0.9);
            font-size: 0.95rem;
            margin: 0.5rem 0;
        }

        .contact-method a {
            color: var(--accent);
            text-decoration: none;
            font-weight: 600;
            transition: color 0.3s;
        }

        .contact-method a:hover {
            color: var(--white);
        }

        /* ===== FOOTER ===== */
        footer {
            background: var(--gray-900);
            color: var(--gray-400);
            padding: 4rem 0 2rem;
            border-top: 1px solid var(--gray-200);
        }

        .footer-content {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 3rem;
            margin-bottom: 3rem;
            padding-bottom: 2rem;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }

        .footer-section h4 {
            color: var(--white);
            margin-bottom: 1rem;
            font-weight: 700;
        }

        .footer-section a,
        .footer-section p {
            color: var(--gray-400);
            font-size: 0.9rem;
            text-decoration: none;
            margin-bottom: 0.5rem;
            display: block;
            transition: color 0.3s;
        }

        .footer-section a:hover {
            color: var(--accent);
        }

        .footer-bottom {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 1rem;
            font-size: 0.85rem;
            color: var(--gray-500);
        }

        /* ===== CHAT WIDGET ===== */
        .chat-widget {
            position: fixed;
            bottom: 3rem;
            right: 2rem;
            z-index: 999;
        }

        .chat-btn {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            background: linear-gradient(135deg, #001f5c, #0066cc);
            border: none;
            color: var(--white);
            font-size: 1.5rem;
            cursor: pointer;
            box-shadow: 0 4px 15px rgba(0, 31, 92, 0.4);
            transition: all 0.3s;
            display: flex;
            align-items: center;
            justify-content: center;
            animation: pulse 2s infinite;
        }

        @keyframes pulse {
            0%, 100% {
                box-shadow: 0 4px 15px rgba(0, 31, 92, 0.4);
                transform: scale(1);
            }
            50% {
                box-shadow: 0 4px 30px rgba(0, 31, 92, 0.7);
                transform: scale(1.05);
            }
        }

        .chat-btn:hover {
            animation: none;
            transform: scale(1.1);
            box-shadow: 0 6px 25px rgba(0, 31, 92, 0.6);
        }

        .chat-modal {
            position: absolute;
            bottom: 80px;
            right: 0;
            background: var(--white);
            border: 1px solid var(--gray-200);
            border-radius: 1rem;
            width: 350px;
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.3s, opacity 0.3s;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
            opacity: 0;
        }

        .chat-modal.active {
            max-height: 500px;
            opacity: 1;
        }

        .chat-header {
            background: linear-gradient(135deg, var(--primary), var(--primary-light));
            padding: 1.5rem;
            color: var(--white);
        }

        .chat-header h3 {
            font-size: 1.1rem;
            font-weight: 700;
            margin: 0 0 0.5rem 0;
        }

        .chat-header p {
            font-size: 0.85rem;
            margin: 0;
            opacity: 0.9;
        }

        .chat-options {
            padding: 1.5rem;
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
        }

        .chat-option {
            background: var(--gray-50);
            border: 1px solid var(--gray-200);
            color: var(--gray-700);
            padding: 1rem;
            border-radius: 0.5rem;
            cursor: pointer;
            transition: all 0.3s;
            text-align: left;
            font-weight: 500;
            font-size: 0.9rem;
            text-decoration: none;
            display: block;
        }

        .chat-option:hover {
            background: var(--accent);
            color: var(--white);
            border-color: var(--accent);
            transform: translateX(-3px);
        }

        @media (max-width: 640px) {
            .chat-widget {
                bottom: 1.5rem;
                right: 1rem;
            }

            .chat-btn {
                width: 50px;
                height: 50px;
            }

            .chat-modal {
                width: 280px;
                bottom: 60px;
            }

            .grid.cols-3,
            .grid.cols-4 {
                grid-template-columns: 1fr;
            }
        }

        /* ===== ANIMATIONS ===== */
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .card,
        .testimonial-card,
        .faq-item {
            animation: fadeInUp 0.5s ease-out;
        }
    </style>
</head>
