                <a href="https://wa.me/5517991040360?text=Olá!%20Gostaria%20de%20informações%20sobre%20MEI" target="_blank" class="chat-option">👤 MEI/PJ</a>
                <a href="https://wa.me/5517991040360?text=Olá%20Azucon!%20Tenho%20uma%20dúvida" target="_blank" class="chat-option">💬 Outro assunto</a>
            </div>
        </div>
    </div>

    <script>
        function openChat() {
            document.getElementById('chatModal').classList.toggle('active');
        }

        function toggleChat() {
            openChat();
        }

        function toggleFaq(element) {
            const item = element.parentElement;
            item.classList.toggle('active');
        }

        document.addEventListener('click', function(e) {
            const chatWidget = document.querySelector('.chat-widget');
            if (!chatWidget.contains(e.target)) {
                document.getElementById('chatModal').classList.remove('active');
            }
        });
    </script>
</body>
</html>
